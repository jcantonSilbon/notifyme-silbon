# Database (Supabase)
# Use pooled connection for the app, direct for migrations
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Shopify (custom app - permanent access token from Shopify Admin → Settings → Apps → Develop apps)
SHOPIFY_ACCESS_TOKEN="shpat_xxxxx"
SHOPIFY_SHOP_DOMAIN="silbon.myshopify.com"
SHOPIFY_API_VERSION="2024-10"
# Get this from: Shopify Admin → Settings → Notifications → Webhooks → signing secret
SHOPIFY_WEBHOOK_SECRET="whsec_xxxxx"

# Resend (transactional email - https://resend.com)
# Requires domain silbon.com to be verified in Resend dashboard before going live
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="notificaciones@silbon.com"
EMAIL_FROM_NAME="Silbon"

# Admin dashboard (generate with: openssl rand -hex 32)
ADMIN_TOKEN="change-me-to-a-long-random-secret"

# Vercel cron job protection (generate with: openssl rand -hex 32)
CRON_SECRET="change-me-to-another-long-random-secret"

# Multi-location filtering (optional)
# Set to a specific Shopify location ID to only process webhooks from that location
# Leave blank to process all locations (correct for single-warehouse stores)
NOTIFY_LOCATION_ID=""

# App public URL (used to build product links in emails)
APP_URL="https://notifyme.vercel.app"
STORE_URL="https://silbon.com"

# Environment
NODE_ENV="development"
PORT="3000"
