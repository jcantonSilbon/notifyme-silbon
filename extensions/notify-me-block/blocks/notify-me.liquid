{%- comment -%}
  Notify Me App Block — Silbon Back-in-Stock Notifications
  ─────────────────────────────────────────────────────────
  OS 2.0 App Block placed on the product page via the theme editor.

  Variant selection strategy:
    1. ALL variants OOS   → render own selector (theme picker likely hidden)
    2. SOME variants OOS  → sync with the theme's picker via events / input[name="id"]
    3. Single variant OOS → auto-select, show form directly
    4. Variant in stock   → block is hidden; add-to-cart is the CTA

  Subscription is always tied to the exact variantId the user chose.
{%- endcomment -%}

{%- comment -%} Variant data embedded at render time — no runtime fetch needed {%- endcomment -%}
<script type="application/json" id="notify-me-product-data">
{
  "id": {{ product.id }},
  "handle": {{ product.handle | json }},
  "title": {{ product.title | json }},
  "has_only_default_variant": {{ product.has_only_default_variant | json }},
  "option_names": {{ product.options | json }},
  "variants": [
    {%- for variant in product.variants -%}
    {
      "id": {{ variant.id }},
      "title": {{ variant.title | json }},
      "options": {{ variant.options | json }},
      "option1": {{ variant.option1 | json }},
      "inventory_item_id": {{ variant.inventory_item_id | json }},
      "available": {{ variant.available }}
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

<div
  id="notify-me-container"
  class="notify-me"
  data-backend-url="{{ block.settings.backend_url }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  style="display: none;"
  aria-live="polite"
>
  <button
    type="button"
    id="notify-me-open"
    class="notify-me__trigger"
    aria-haspopup="dialog"
    aria-controls="notify-me-modal"
    aria-expanded="false"
  >
    <span class="notify-me__trigger-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
        <path d="M12 3a4 4 0 0 0-4 4v1.2c0 .9-.3 1.8-.9 2.5L5.7 12a1 1 0 0 0 .8 1.7h11a1 1 0 0 0 .8-1.7l-1.4-1.3a3.8 3.8 0 0 1-.9-2.5V7a4 4 0 0 0-4-4Zm0 18a2.7 2.7 0 0 0 2.5-1.7h-5A2.7 2.7 0 0 0 12 21Z" fill="currentColor"/>
      </svg>
    </span>
    <span class="notify-me__trigger-text">AVISAR POR EMAIL</span>
  </button>

  <div id="notify-me-modal" class="notify-me__modal" style="display: none;" aria-hidden="true">
    <div id="notify-me-backdrop" class="notify-me__backdrop"></div>
    <div
      class="notify-me__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="notify-me-title"
    >
      <button type="button" id="notify-me-close" class="notify-me__close" aria-label="Cerrar">
        ×
      </button>

      <div class="notify-me__inner">
        <p id="notify-me-title" class="notify-me__heading">{{ block.settings.heading_text }}</p>

        {%- comment -%}
          Own variant selector.
          Shown by JS only when the theme selector is not usable.
          The control is rendered dynamically by notify-me.js and becomes
          mandatory for multi-variant products without a usable theme picker.
        {%- endcomment -%}
        <div id="notify-me-selector-wrap" style="display: none;">
          <label id="notify-me-selector-label" class="notify-me__selector-label" for="notify-me-variant-select"></label>
          <select id="notify-me-variant-select" class="notify-me__select"></select>
        </div>

        <form id="notify-me-form" class="notify-me__form" novalidate>
          {%- comment -%} Honeypot — must remain empty {%- endcomment -%}
          <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
            <label for="notify-me-honeypot">Leave this empty</label>
            <input type="text" id="notify-me-honeypot" name="honeypot" tabindex="-1" autocomplete="off" value="" />
          </div>

          <input type="hidden" id="notify-me-product-id"     name="productId"     value="{{ product.id }}" />
          <input type="hidden" id="notify-me-product-handle" name="productHandle" value="{{ product.handle }}" />
          <input type="hidden" id="notify-me-variant-id"     name="variantId"     value="" />
          <input type="hidden" id="notify-me-inventory-item-id" name="inventoryItemId" value="" />
          <input type="hidden" id="notify-me-product-title"  name="productTitle"  value="{{ product.title | escape }}" />
          <input type="hidden" id="notify-me-variant-title"  name="variantTitle"  value="" />

          <div class="notify-me__field-group">
            <label for="notify-me-email" class="notify-me__label">Correo electrónico</label>
            <input
              type="email"
              id="notify-me-email"
              name="email"
              class="notify-me__input"
              placeholder="tu@email.com"
              required
              autocomplete="email"
              inputmode="email"
            />
          </div>

          <button
            type="submit"
            id="notify-me-submit"
            class="notify-me__button button button--full-width button--secondary"
          >
            Notificarme cuando esté disponible
          </button>
        </form>

        <div id="notify-me-message" class="notify-me__message" role="alert" aria-live="assertive" style="display: none;"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .notify-me {
    margin-top: 1rem;
  }

  .notify-me__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 2.75rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgb(var(--color-foreground));
    border-radius: 0;
    background: transparent;
    color: rgb(var(--color-foreground));
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    text-transform: uppercase;
  }

  .notify-me__trigger:hover {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  .notify-me__trigger-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    flex: 0 0 auto;
  }

  .notify-me__trigger-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .notify-me__trigger-text {
    line-height: 1;
  }

  .notify-me__modal {
    position: fixed;
    inset: 0;
    z-index: 999;
  }

  .notify-me__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .notify-me__dialog {
    position: relative;
    z-index: 1;
    width: min(28rem, calc(100vw - 2rem));
    margin: 12vh auto 0;
    background: rgb(var(--color-background));
    border-radius: 14px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .notify-me__inner {
    position: relative;
    padding: 1.5rem;
    background: rgb(var(--color-background));
  }

  .notify-me__close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 1;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .notify-me__heading {
    margin: 0 2rem 1rem 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  /* ── Own variant selector ── */
  .notify-me__selector-label {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }

  .notify-me__select {
    width: 100%;
    margin-bottom: 0.875rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--inputs-radius, 4px);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-size: 1rem;
    box-sizing: border-box;
  }

  .notify-me__select:focus {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  /* ── Form ── */
  .notify-me__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .notify-me__field-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .notify-me__label {
    font-size: 0.875rem;
    color: rgb(var(--color-foreground));
  }

  .notify-me__input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--inputs-radius, 4px);
    font-size: 1rem;
    color: rgb(var(--color-foreground));
    background: rgb(var(--color-background));
    box-sizing: border-box;
  }

  .notify-me__input:focus {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  .notify-me__button { cursor: pointer; }

  .notify-me__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .notify-me__message {
    margin-top: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .notify-me__message--success {
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  .notify-me__message--error {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  body.notify-me-modal-open {
    overflow: hidden;
  }
</style>

<script src="{{ 'notify-me.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Notificación de Restock",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "url",
      "id": "backend_url",
      "label": "URL del backend",
      "info": "URL completa del servidor NotifyMe (p.ej. https://notifyme-silbon.vercel.app)"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Título del formulario",
      "default": "Avísame cuando esté disponible"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Avisarme"
    }
  ]
}
{% endschema %}
